{
  "name": "@jskit-ai/jskit-cli",
  "version": "0.2.79",
  "description": "Bundle and package orchestration CLI for JSKIT apps.",
  "type": "module",
  "files": [
    "bin",
    "src",
    "bundles"
  ],
  "bin": {
    "jskit": "bin/jskit.js"
  },
  "exports": {
    ".": "./src/index.js",
    "./server": "./src/server/index.js",
    "./client": "./src/client/index.js"
  },
  "scripts": {
    "test": "node --test"
  },
  "dependencies": {
    "@jskit-ai/jskit-catalog": "0.1.78",
