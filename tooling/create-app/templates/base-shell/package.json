{
  "name": "__APP_NAME__",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Minimal JSKIT base app (Fastify + Vue)",
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "server": "node ./bin/server.js",
    "server:all": "node ./bin/server.js",
    "server:home": "SERVER_SURFACE=home node ./bin/server.js",
    "server:console": "SERVER_SURFACE=console node ./bin/server.js",
    "start": "node ./bin/server.js",
    "devlinks": "bash ./scripts/link-local-jskit-packages.sh",
    "dev": "vite",
    "dev:all": "vite",
    "dev:home": "VITE_SURFACE=home vite",
    "dev:console": "VITE_SURFACE=console vite",
    "build": "vite build",
    "build:all": "vite build",
    "build:home": "VITE_SURFACE=home vite build",
    "build:console": "VITE_SURFACE=console vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "test": "node --test",
    "test:client": "vitest run tests/client",
    "verify": "npm run lint && npm run test && npm run test:client && npm run build && npx jskit doctor",
    "release": "bash ./scripts/release.sh",
    "jskit:update": "bash ./scripts/update-jskit-packages.sh"
  },
  "dependencies": {
    "@local/main": "file:packages/main",
    "@fastify/static": "^8.3.0",
    "@fastify/type-provider-typebox": "^6.1.0",
    "@jskit-ai/kernel": "0.x",
    "fastify": "^5.7.4",
    "vue": "^3.5.13",
    "vue-router": "^5.0.4",
    "vuetify": "^4.0.0",
    "@jskit-ai/http-runtime": "0.x"
  },
  "devDependencies": {
    "@jskit-ai/config-eslint": "0.x",
    "@jskit-ai/jskit-cli": "0.x",
    "@vitejs/plugin-vue": "^5.2.1",
    "eslint": "^9.39.1",
    "vite": "^6.1.0",
    "vitest": "^4.0.18"
  }
}
