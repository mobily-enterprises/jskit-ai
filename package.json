{
  "name": "jskit-monorepo",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "npm run -w apps/jskit-value-app dev --",
    "app:create": "node ./packages/tooling/create-app/bin/jskit-create-app.js",
    "app:create:interactive": "node ./packages/tooling/create-app/bin/jskit-create-app.js --interactive",
    "jskit": "node ./packages/tooling/jskit/bin/jskit.js",
    "cloc:actual": "cloc --vcs=git --include-ext=js,cjs,mjs,jsx,ts,tsx,vue,py,go,rs,java,kt,swift,rb,php,cs,cpp,c,h,sql,sh,bash,zsh,ps1,md,mdx,rst,adoc,txt --exclude-dir=node_modules,dist,build,coverage,.next,.nuxt,.turbo,.cache,storybook-static,vendor,tmp,temp,.output,.vercel .",
    "sloc:actual": "npm run cloc:actual",
    "lint:architecture:client": "eslint --config eslint.architecture.client.mjs --no-error-on-unmatched-pattern \"packages/**/src/**/*.js\" \"apps/**/src/**/*.js\"",
    "test:architecture:client": "node --test tests/architecture/client-architecture.guardrails.test.mjs",
    "test:architecture:shared-ui": "node --test tests/architecture/client-shared-ui.guardrails.test.mjs",
    "test:framework": "node --test tests/framework/*.test.mjs",
    "framework:lint-descriptors": "node ./scripts/framework/validate-descriptors.mjs",
    "framework:generate-descriptors": "node ./scripts/framework/generate-package-descriptor.mjs --dry-run",
    "framework:sync-descriptor-deps": "node ./scripts/framework/sync-descriptor-deps.mjs --dry-run",
    "framework:check-descriptor-drift": "node ./scripts/framework/check-descriptor-drift.mjs",
    "framework:check-runtime-layout": "node ./scripts/framework/check-package-runtime-layout.mjs",
    "framework:check-runtime-layout:strict": "node ./scripts/framework/check-package-runtime-layout.mjs --strict",
    "framework:check-import-boundaries": "node ./scripts/framework/check-import-boundaries.mjs",
    "framework:check-import-boundaries:strict": "node ./scripts/framework/check-import-boundaries.mjs --strict",
    "framework:check-app-ownership": "node ./scripts/framework/check-app-ownership.mjs",
    "framework:check-app-ownership:strict": "node ./scripts/framework/check-app-ownership.mjs --strict",
    "framework:stage1-checks": "npm run framework:check-runtime-layout && npm run framework:check-import-boundaries && npm run framework:check-app-ownership",
    "test:architecture:db": "node --test tests/architecture/server-db-architecture.guardrails.test.mjs"
  },
  "workspaces": [
    "apps/*",
    "packages/*",
    "packages/*/*"
  ],
  "devDependencies": {
    "cloc": "^2.6.0-cloc"
  }
}
