{
  "all": true,
  "check-coverage": true,
  "per-file": false,
  "branches": 93,
  "functions": 93,
  "lines": 95,
  "statements": 95,
  "reporter": ["text-summary", "lcov"],
  "report-dir": ".artifacts/coverage/backend",
  "temp-directory": ".artifacts/coverage/backend/tmp",
  "exclude": [
    ".artifacts/**",
    "coverage/**",
    "coverage-client/**",
    "coverage-vue/**",
    "dist/**",
    "node_modules/**",
    "tests/**",
    "src/**",
    "migrations/**",
    "seeds/**",
    "server.js",
    "bin/server.js",
    "knexfile.cjs",
    "vite.config.mjs",
    "vitest.vue.config.mjs",
    "playwright.config.mjs",
    "eslint.config.mjs"
  ]
}
