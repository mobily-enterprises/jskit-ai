# Repository-owned behavior/policy defaults live under /config (app, chat, ai, billing, retention).
# .env is only for runtime/deployment values and secrets.
# Variables with non-empty runtime defaults are commented out intentionally.
# Uncomment and change them only when you want to override the built-in default.

############################################
# CORE SERVER SETTINGS
############################################

# Runtime mode used by server safety checks and startup behavior. Possible values: development | production | test
# NODE_ENV=development

# HTTP port for the backend server. Possible values: integer 1-65535
# PORT=3000

# Optional logger override.
# Available values: fatal | error | warn | info | debug | trace
# Leave empty to use automatic level by NODE_ENV.
LOG_LEVEL=

# Optional scoped debug logging filter. Comma-separated scopes/wildcards.
# Available scopes in this scaffold:
# - billing.checkout
# - billing.worker
# Examples: billing.checkout | billing.* | billing.*,-billing.worker
# Debug logs emit only when scope matches this list and LOG_LEVEL is debug or trace.
# Empty disables scoped debug logs.
LOG_DEBUG_SCOPES=

# Trust X-Forwarded-* headers from a trusted proxy/load balancer. Possible values: true | false
# TRUST_PROXY=false

############################################
# DATABASE SETTINGS
############################################

# MySQL host. Possible values: hostname or IP address
# DB_HOST=127.0.0.1

# MySQL port. Possible values: integer 1-65535
# DB_PORT=3306

# Primary application database name. Possible values: valid MySQL database name
# DB_NAME=material-app

# Test database name. If empty, tooling falls back to "${DB_NAME}_test". Possible values: empty | valid MySQL database name
DB_TEST_NAME=

# MySQL username used by app and migrations. Possible values: valid MySQL username (do not use root in production)
# DB_USER=jskit-app

# MySQL password. Possible values: empty | any strong password string
DB_PASSWORD=

# Connection pool max size. Possible values: integer >= 1
# DB_POOL_MAX=10

############################################
# AUTH & PUBLIC URL SETTINGS
############################################

# Auth provider id. Possible values: supabase
# AUTH_PROVIDER=supabase

# Supabase auth URL (required in production when AUTH_PROVIDER=supabase). Possible values: empty | absolute https URL (example: https://YOUR-PROJECT.supabase.co)
AUTH_SUPABASE_URL=

# Supabase publishable key (required in production when AUTH_PROVIDER=supabase). Possible values: empty | Supabase publishable key string
AUTH_SUPABASE_PUBLISHABLE_KEY=

# JWT audience expected for access tokens. Possible values: non-empty string (usually "authenticated")
# AUTH_JWT_AUDIENCE=authenticated

# Public frontend origin used for auth redirects (for example /reset-password). Possible values: empty | absolute http(s) URL (example: http://localhost:5173)
APP_PUBLIC_URL=

############################################
# RATE LIMIT SETTINGS
############################################

# Backend rate limiter mode. Possible values: memory | redis
# RATE_LIMIT_MODE=memory

# Redis connection URL when RATE_LIMIT_MODE=redis. Possible values: empty | redis://... | rediss://...
REDIS_URL=

############################################
# WORKER & RETENTION SETTINGS
############################################

# Worker job concurrency (`npm run worker`). Possible values: integer >= 1
# WORKER_CONCURRENCY=2

# Max auto-requeue attempts for lock-held terminal failures. Possible values: integer >= 0 (set 0 to disable auto-requeue)
# WORKER_LOCK_HELD_REQUEUE_MAX=3

# Retention sweep distributed lock TTL in milliseconds. Possible values: integer >= 1
# WORKER_RETENTION_LOCK_TTL_MS=1800000

# Retention sweep batch size. Possible values: integer >= 1
# RETENTION_BATCH_SIZE=1000

############################################
# SMS SETTINGS
############################################

# SMS provider driver. Possible values: none | plivo
# SMS_DRIVER=none

# Plivo Auth ID (required when SMS_DRIVER=plivo). Possible values: empty | non-empty string from Plivo dashboard
PLIVO_AUTH_ID=

# Plivo Auth Token (required when SMS_DRIVER=plivo). Possible values: empty | non-empty string from Plivo dashboard
PLIVO_AUTH_TOKEN=

# Plivo source number in E.164 format (required when SMS_DRIVER=plivo). Possible values: empty | +[country code][number] (example: +14155550123)
PLIVO_SOURCE_NUMBER=

############################################
# STORAGE SETTINGS
############################################

# Avatar storage backend. Possible values: fs
# AVATAR_STORAGE_DRIVER=fs

# Filesystem base path for avatar storage. Empty = "<project>/data/storage". Possible values: empty | absolute or relative filesystem path
AVATAR_STORAGE_FS_BASE_PATH=

# Public URL path prefix for avatar files. Possible values: URL path beginning with "/" (example: /uploads)
# AVATAR_PUBLIC_BASE_PATH=/uploads

# Chat attachment storage backend. Possible values: fs
# CHAT_ATTACHMENT_STORAGE_DRIVER=fs

# Filesystem base path for chat attachments. Empty = "<project>/data/storage". Possible values: empty | absolute or relative filesystem path
CHAT_ATTACHMENT_STORAGE_FS_BASE_PATH=

############################################
# EMAIL SETTINGS (WORKSPACE INVITES)
############################################

# Workspace invite email driver. Possible values: none | smtp
# WORKSPACE_INVITE_EMAIL_DRIVER=none

# SMTP host (required when WORKSPACE_INVITE_EMAIL_DRIVER=smtp). Possible values: empty | hostname
SMTP_HOST=

# SMTP port (required when WORKSPACE_INVITE_EMAIL_DRIVER=smtp). Possible values: integer 1-65535
# SMTP_PORT=587

# SMTP secure transport flag. Possible values: true | false
# SMTP_SECURE=false

# SMTP username (required when WORKSPACE_INVITE_EMAIL_DRIVER=smtp). Possible values: empty | non-empty string
SMTP_USERNAME=

# SMTP password (required when WORKSPACE_INVITE_EMAIL_DRIVER=smtp). Possible values: empty | non-empty string
SMTP_PASSWORD=

# Sender email address (required when WORKSPACE_INVITE_EMAIL_DRIVER=smtp). Possible values: empty | valid email address
SMTP_FROM=

############################################
# OBSERVABILITY SETTINGS
############################################

# Enable /api/metrics endpoint. Possible values: true | false
# METRICS_ENABLED=true

# Optional bearer token required for GET /api/metrics. Possible values: empty | non-empty secret token
METRICS_BEARER_TOKEN=

############################################
# AI SETTINGS
############################################

# AI provider ID. Possible values: openai
# AI_PROVIDER=openai

# API key for configured AI provider (required when AI feature is enabled). Possible values: empty | provider API key string
AI_API_KEY=

# Optional custom OpenAI-compatible base URL. Possible values: empty | absolute http(s) URL
AI_BASE_URL=

# AI request timeout in milliseconds. Possible values: integer >= 1
# AI_TIMEOUT_MS=45000

############################################
# BILLING SETTINGS (SHARED)
############################################

# HMAC secret for billing operation key derivation. Possible values: empty | high-entropy secret string
BILLING_OPERATION_KEY_SECRET=

# HMAC secret for provider idempotency key derivation. Possible values: empty | high-entropy secret string
BILLING_PROVIDER_IDEMPOTENCY_KEY_SECRET=

############################################
# BILLING SETTINGS (STRIPE)
############################################

# Stripe API secret key (required when billing is enabled and provider is stripe). Possible values: empty | Stripe secret key (for example sk_live_...)
BILLING_STRIPE_SECRET_KEY=

# Stripe API version (required when billing is enabled and provider is stripe). Possible values: empty | Stripe API version string (for example 2024-06-20)
BILLING_STRIPE_API_VERSION=

# Stripe webhook signing secret. Possible values: empty | Stripe webhook secret (for example whsec_...)
BILLING_STRIPE_WEBHOOK_ENDPOINT_SECRET=

# Stripe SDK max network retries. Possible values: integer >= 0
# BILLING_STRIPE_MAX_NETWORK_RETRIES=2

# Stripe SDK timeout in milliseconds. Possible values: integer >= 1
# BILLING_STRIPE_TIMEOUT_MS=30000

############################################
# BILLING SETTINGS (PADDLE)
############################################

# Paddle API key (required when billing is enabled and provider is paddle). Possible values: empty | Paddle API key string
BILLING_PADDLE_API_KEY=

# Paddle API base URL. Possible values: absolute https URL
# BILLING_PADDLE_API_BASE_URL=https://api.paddle.com

# Paddle webhook signing secret. Possible values: empty | Paddle webhook secret string
BILLING_PADDLE_WEBHOOK_ENDPOINT_SECRET=

# Paddle SDK timeout in milliseconds. Possible values: integer >= 1
# BILLING_PADDLE_TIMEOUT_MS=30000

############################################
# PATHS & FRONTEND BUILD SETTINGS
############################################

# RBAC manifest path. Relative paths resolve from project root. Possible values: readable relative or absolute file path
# RBAC_MANIFEST_PATH=./shared/auth/rbac.manifest.json

# Frontend build directory served by server.js. Possible values: relative directory from project root or absolute directory path
# FRONTEND_DIST_DIR=dist

############################################
# FRONTEND DEV SETTINGS (VITE_)
############################################

# Vite dev server port (`npm run dev`). Possible values: integer >= 1
# VITE_DEV_PORT=5173

# Vite proxy target for /api and /uploads during local dev. Possible values: absolute http(s) URL
# VITE_API_PROXY_TARGET=http://localhost:3000

# Desktop navigation drawer behavior in the frontend app. Possible values: collapsible | permanent
# VITE_DESKTOP_DRAWER_BEHAVIOR=collapsible

# Explicit realtime socket base URL. Empty means same-origin. Possible values: empty | absolute http(s) URL
VITE_REALTIME_URL=
