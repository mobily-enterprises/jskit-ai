{
  "version": 1,
  "defaultInviteRole": "member",
  "roles": {
    "owner": {
      "assignable": false,
      "permissions": ["*"]
    },
    "admin": {
      "assignable": true,
      "permissions": [
        "workspace.members.invite",
        "workspace.members.view",
        "workspace.members.manage",
        "workspace.invites.revoke",
        "workspace.settings.view",
        "workspace.settings.update",
        "workspace.roles.view",
        "workspace.ai.transcripts.read",
        "workspace.ai.transcripts.export",
        "workspace.billing.manage",
        "history.read",
        "history.write",
        "chat.read",
        "chat.write",
        "projects.read",
        "projects.write",
        "social.read",
        "social.write",
        "social.moderate"
      ]
    },
    "member": {
      "assignable": true,
      "permissions": [
        "history.read",
        "history.write",
        "chat.read",
        "chat.write",
        "projects.read",
        "projects.write",
        "social.read",
        "social.write"
      ]
    },
    "viewer": {
      "assignable": true,
      "permissions": ["history.read", "projects.read", "social.read"]
    }
  }
}
